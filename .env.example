# AssembleAI environment example
# Copy this file to .env.local for local development.
# Never put real secrets in VITE_* variables; Vite exposes them to the browser.

# Client-safe endpoint configuration
VITE_INTENT_ENDPOINT=http://localhost:8787/api/intent
VITE_PHOTO_CHECK_ENDPOINT=http://localhost:8787/api/photo-check
# When set, selecting a specific microphone (e.g. Ray-Ban Meta glasses) records
# audio from that device and transcribes it via this endpoint, instead of the
# browser Web Speech API (which can only use the OS default input).
VITE_STT_ENDPOINT=http://localhost:8787/api/stt
VITE_STT_PROVIDER=webspeech
VITE_TTS_PROVIDER=webspeech
VITE_AGENT_DEBUG=1

# Agent backend configuration
AGENT_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5323
AGENT_REQUEST_TIMEOUT_MS=8000
AGENT_MODEL_PROVIDER=openai
AGENT_INTENT_MODEL=replace_with_structured_output_model
AGENT_VISION_MODEL=replace_with_vision_model
OPENAI_API_KEY=sk-proj_replace_me
# Speech-to-text model used by /api/stt (OpenAI audio transcription)
STT_LLM_MODEL=gpt-4o-mini-transcribe

# Optional hosted speech providers
STT_PROVIDER=webspeech
DEEPGRAM_API_KEY=dg_replace_me
ASSEMBLYAI_API_KEY=assemblyai_replace_me
TTS_PROVIDER=browser
ELEVENLABS_API_KEY=elevenlabs_replace_me
ELEVENLABS_VOICE_ID=voice_replace_me

# Optional demo operations
AGENT_EVENT_LOG_LEVEL=debug
SENTRY_DSN=https://public@example.ingest.sentry.io/project
DATABASE_URL=postgres://assembleai:assembleai@localhost:5432/assembleai
