  "steps": [
    {
      "index": 1,
      "title": "Insert the wood dowels",
      "action": "Press all 16 wood dowels into the edge holes of the bottom shelf, fixed shelf, top shelf, and front bottom rail.",
      "partsNeeded": [
        { "partId": "bottom-panel", "quantity": 1 },
        { "partId": "fixed-shelf", "quantity": 1 },
        { "partId": "top-panel", "quantity": 1 },
        { "partId": "front-rail", "quantity": 1 },
        { "partId": "wood-dowel", "quantity": 16 }
      ],
      "cameraView": "dowel-prep",
      "highlightParts": ["bottom-panel", "fixed-shelf", "top-panel", "front-rail", "wood-dowel"],
      "commonMistake": "Use the small edge holes shown in the manual. Do not put dowels into the larger cam-lock holes.",
      "toolNeeded": "Hands",
      "manualFig": "Fig. 3",
      "estMinutes": 4
    },
    {
      "index": 2,
      "title": "Install the cam screws",
      "action": "Thread the 12 cam screws into the marked holes on the two tall side panels.",
      "partsNeeded": [
        { "partId": "side-panel-left", "quantity": 1 },
        { "partId": "side-panel-right", "quantity": 1 },
        { "partId": "cam-screw", "quantity": 12 }
      ],
      "cameraView": "side-screw-detail",
      "highlightParts": ["side-panel-left", "side-panel-right", "cam-screw"],
      "commonMistake": "Drive each cam screw straight. A tilted cam screw will not catch the cam lock later.",
      "toolNeeded": "Flat screwdriver",
      "manualFig": "Fig. 4",
      "estMinutes": 5
    },
    {
      "index": 3,
      "title": "Seat the shelves on the first side",
      "action": "With the first side panel lying on the floor, seat the dowelled bottom shelf, fixed shelf, and top shelf into the matching holes.",
      "partsNeeded": [
        { "partId": "side-panel-left", "quantity": 1 },
        { "partId": "bottom-panel", "quantity": 1 },
        { "partId": "fixed-shelf", "quantity": 1 },
        { "partId": "top-panel", "quantity": 1 },
        { "partId": "wood-dowel", "quantity": 12 }
      ],
      "cameraView": "first-side-assembly",
      "highlightParts": ["side-panel-left", "bottom-panel", "fixed-shelf", "top-panel", "wood-dowel"],
      "commonMistake": "Keep the dowels straight as the panels go in. The manual calls out the correct upright dowel orientation here.",
      "toolNeeded": "Hands",
      "manualFig": "Fig. 5",
      "estMinutes": 4
    },
    {
      "index": 4,
      "title": "Lock the first four cams",
      "action": "Insert four cam locks and turn them to pull the bottom and shelf panels tight to the first side panel.",
      "partsNeeded": [
        { "partId": "cam-lock", "quantity": 4 }
      ],
      "cameraView": "cam-lock-detail",
      "highlightParts": ["cam-lock", "side-panel-left", "bottom-panel", "fixed-shelf"],
      "commonMistake": "The cam lock opening must face the cam screw before you turn it. If it spins freely, rotate it back and reseat it.",
      "toolNeeded": "Phillips screwdriver",
      "manualFig": "Fig. 6",
      "estMinutes": 3
    },
    {
      "index": 5,
      "title": "Fit the front rail",
      "action": "Seat the front bottom rail on its dowels and lock it with two cam locks.",
      "partsNeeded": [
        { "partId": "front-rail", "quantity": 1 },
        { "partId": "cam-lock", "quantity": 2 }
      ],
      "cameraView": "front-rail",
      "highlightParts": ["front-rail", "cam-lock"],
      "commonMistake": "The rail belongs on the front edge of the base assembly. Match the manual notch before locking.",
      "toolNeeded": "Phillips screwdriver",
      "manualFig": "Fig. 7",
      "estMinutes": 3
    },
    {
      "index": 6,
      "title": "Lower the second side panel",
      "action": "Lower the second side panel over the exposed dowels and cam screws, keeping all shelf ends aligned.",
      "partsNeeded": [
        { "partId": "side-panel-right", "quantity": 1 },
        { "partId": "wood-dowel", "quantity": 12 },
        { "partId": "cam-screw", "quantity": 6 }
      ],
      "cameraView": "second-side-panel",
      "highlightParts": ["side-panel-right", "wood-dowel", "cam-screw"],
      "commonMistake": "Do not force the side panel down. If it resists, lift it and realign the dowels.",
      "toolNeeded": "Hands",
      "manualFig": "Fig. 8",
      "estMinutes": 4
    },
    {
      "index": 7,
      "title": "Lock the remaining cams",
      "action": "Insert and turn the remaining six cam locks along the second side panel.",
      "partsNeeded": [
        { "partId": "cam-lock", "quantity": 6 }
      ],
      "cameraView": "remaining-cams",
      "highlightParts": ["cam-lock", "side-panel-right"],
      "commonMistake": "Tighten the cams evenly across the side instead of fully tightening one end first.",
      "toolNeeded": "Phillips screwdriver",
      "manualFig": "Fig. 6",
      "estMinutes": 3
    },
    {
      "index": 8,
      "title": "Mark the back panel line",
      "action": "Use a pencil to mark the center lines on the rear edges where the folded back panel will be nailed.",
      "partsNeeded": [
        { "partId": "back-panel", "quantity": 1 }
      ],
      "cameraView": "back-mark",
      "highlightParts": ["back-panel", "side-panel-left", "side-panel-right"],
      "commonMistake": "Make the marks before the back panel covers the rails. The nail line keeps the nails in the frame.",
      "toolNeeded": "Pencil",
      "manualFig": "Fig. 9",
      "estMinutes": 2
    },
    {
      "index": 9,
      "title": "Slide in the folded back panel",
      "action": "Unfold the back panel and slide it into the rear grooves with the finished face toward the shelves.",
      "partsNeeded": [
        { "partId": "back-panel", "quantity": 1 }
      ],
      "cameraView": "back-panel",
      "highlightParts": ["back-panel"],
      "commonMistake": "Keep the smooth face toward the inside of the bookcase. The folded seam should sit flat before nailing.",
      "toolNeeded": "Hands",
      "manualFig": "Fig. 10",
      "estMinutes": 4
    },
    {
      "index": 10,
      "title": "Rule the nail guide line",
      "action": "Use a ruler and pencil to continue the nail guide line across the back panel.",
      "partsNeeded": [
        { "partId": "back-panel", "quantity": 1 }
      ],
      "cameraView": "nail-line",
      "highlightParts": ["back-panel"],
      "commonMistake": "Do not guess the nail line. The manual uses a ruler so the nails land in the center support.",
      "toolNeeded": "Pencil and ruler",
      "manualFig": "Fig. 11",
      "estMinutes": 2
    },
    {
      "index": 11,
      "title": "Nail the back panel",
      "action": "Hammer all 18 back panel nails along the marked lines to square and stiffen the bookcase.",
      "partsNeeded": [
        { "partId": "back-panel", "quantity": 1 },
        { "partId": "back-nail", "quantity": 18 }
      ],
      "cameraView": "back-nails",
      "highlightParts": ["back-panel", "back-nail"],
      "commonMistake": "Keep the back panel flush with the outer edges before nailing. A shifted back panel will twist the case.",
      "toolNeeded": "Hammer",
      "manualFig": "Fig. 12",
      "estMinutes": 6
    },
    {
      "index": 12,
      "title": "Install the wall brackets",
      "action": "Stand the bookcase upright. Attach the two wall brackets with bracket screws and washers, then use suitable wall screws and plugs for your wall.",
      "partsNeeded": [
        { "partId": "wall-bracket", "quantity": 2 },
        { "partId": "bracket-screw", "quantity": 2 },
        { "partId": "washer", "quantity": 4 }
      ],
      "cameraView": "wall-anchor",
      "highlightParts": ["wall-bracket", "bracket-screw", "washer"],
      "commonMistake": "The wall screws and plugs are not included. Use fasteners suitable for the wall material before loading the bookcase.",
      "toolNeeded": "Phillips screwdriver and drill",
      "manualFig": "Fig. 13",
      "estMinutes": 7
    },
    {
      "index": 13,
      "title": "Insert the shelf pins",
      "action": "Push all 16 shelf support pins into matching holes on the left and right sides.",
      "partsNeeded": [
        { "partId": "shelf-pin", "quantity": 16 }
      ],
      "cameraView": "shelf-pin-detail",
      "highlightParts": ["shelf-pin", "side-panel-left", "side-panel-right"],
      "commonMistake": "Each shelf needs four pins at the same height. One hole off will make the shelf rock.",
      "toolNeeded": "Hands",
      "manualFig": "Fig. 14",
      "estMinutes": 3
    },
    {
      "index": 14,
      "title": "Place the adjustable shelves",
      "action": "Lower the four adjustable shelves onto the support pins and check that each shelf sits flat.",
      "partsNeeded": [
        { "partId": "adjustable-shelf", "quantity": 4 },
        { "partId": "shelf-pin", "quantity": 16 }
      ],
      "cameraView": "complete",
      "highlightParts": ["adjustable-shelf", "shelf-pin"],
      "commonMistake": "Do not load books until the wall attachment is complete and all shelves sit on four pins.",
      "toolNeeded": "Hands",
      "manualFig": "Fig. 15",
      "estMinutes": 4
    }
  ],
